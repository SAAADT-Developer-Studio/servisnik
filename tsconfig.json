{
	"files": [],
	"references": [
		{ "path": "./tsconfig.node.json" },
		{ "path": "./tsconfig.cloudflare.json" }
	],
	"compilerOptions": {
		"checkJs": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"paths": {
			"@better-auth/core": ["./node_modules/@better-auth/core"],
			"@better-auth/core/*": ["./node_modules/@better-auth/core/*"],
			"*": ["./*"],
			"@/*": ["./app/*"],
			"~/*": ["./app/*"]
		}
	}
}
